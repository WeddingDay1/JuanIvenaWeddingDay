<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Wedding of Juan & Ivena</title>
    
    <!-- Google Fonts: Playfair Display (Serif Mewah) & Montserrat (Modern) -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Montserrat:wght@300;400;600&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" rel="stylesheet">
    
    <style>
        :root {
            --gold: #c5a059;
            --dark: #2c2c2c;
            --light-bg: #fdfdfd;
            --text-muted: #757575;
        }

        body { font-family: 'Montserrat', sans-serif; background-color: var(--light-bg); color: var(--dark); overflow-x: hidden; }
        h1, h2, h3, .serif { font-family: 'Playfair Display', serif; }

        /* HERO SECTION */
        .hero {
            height: 100vh;
            background: linear-gradient(rgba(0,0,0,0.2), rgba(0,0,0,0.2)), 
                        url('https://images.unsplash.com/photo-1519741497674-611481863552?auto=format&fit=crop&w=1920&q=80'); /* GANTI DENGAN FOTO UTAMA ANDA */
            background-size: cover;
            background-position: center;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            color: white;
            padding: 20px;
        }
        .hero-content { border: 1px solid rgba(255,255,255,0.5); padding: 50px 30px; backdrop-filter: blur(2px); }
        .hero h1 { font-size: 3.5rem; margin-bottom: 10px; letter-spacing: 3px; }
        .hero p { font-size: 1.1rem; letter-spacing: 5px; text-transform: uppercase; }

        /* SECTION STYLING */
        .section-padding { padding: 100px 20px; }
        .section-title { margin-bottom: 50px; position: relative; display: inline-block; }
        .section-title::after { content: ""; width: 50px; height: 1px; background: var(--gold); position: absolute; bottom: -10px; left: 50%; transform: translateX(-50%); }

        /* DETAILS BOX */
        .event-card { border: 1px solid #eee; padding: 40px; background: white; transition: 0.3s; }
        .event-card:hover { border-color: var(--gold); }

        /* GALLERY */
        .gallery-img { width: 100%; height: 400px; object-fit: cover; margin-bottom: 20px; border-radius: 2px; }

        /* RSVP FORM */
        .rsvp-container { background: #f9f6f2; padding: 60px 40px; border-radius: 5px; }
        .form-control, .form-select { border: none; border-bottom: 1px solid #ccc; border-radius: 0; padding: 15px 5px; background: transparent; }
        .form-control:focus { box-shadow: none; border-color: var(--gold); }
        .btn-gold { background: var(--gold); color: white; border-radius: 0; padding: 12px 40px; letter-spacing: 2px; text-transform: uppercase; font-size: 0.9rem; border: none; transition: 0.4s; }
        .btn-gold:hover { background: var(--dark); color: white; }

        /* WISHES BOX */
        .wish-item { background: white; border-left: 3px solid var(--gold); padding: 20px; margin-bottom: 20px; box-shadow: 0 5px 15px rgba(0,0,0,0.05); text-align: left; }
        .wish-name { font-weight: 600; color: var(--gold); margin-bottom: 5px; }
        .wish-text { font-style: italic; color: var(--text-muted); }

        /* MAP */
        .map-container { filter: grayscale(100%) invert(90%) contrast(90%); }

        @media (max-width: 768px) {
            .hero h1 { font-size: 2.5rem; }
        }
    </style>
</head>
<body>

    <!-- Hero -->
    <section class="hero">
        <div class="hero-content">
            <p>Save The Date</p>
            <h1>Juan & Ivena</h1>
            <p>01 . 05 . 2026</p>
        </div>
    </section>

    <!-- Intro -->
    <section class="container section-padding text-center">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <h2 class="section-title">Our Wedding</h2>
                <p class="lead serif mt-4">"And now these three remain: faith, hope and love. But the greatest of these is love."</p>
                <p class="text-muted mt-3">Kami mengundang Anda untuk berbagi kebahagiaan dalam resepsi pernikahan kami.</p>
            </div>
        </div>
    </section>

    <!-- Details -->
    <section class="container section-padding">
        <div class="row g-4 text-center">
            <div class="col-md-6 offset-md-3">
                <div class="event-card">
                    <h3 class="serif mb-4">Wedding Reception</h3>
                    <p class="mb-1"><strong>Jumat, 1 Mei 2026</strong></p>
                    <p class="mb-4">18:30 WIB - Selesai</p>
                    <hr style="width: 30%; margin: 20px auto; color: var(--gold);">
                    <h4 class="serif">Grand Mercure Mirama Hotel</h4>
                    <p class="text-muted">Jl. Raya Darmo No.68-78, Dr. Soetomo, Kec. Tegalsari, Kota Surabaya, Jawa Timur, 60264</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Map -->
    <section class="map-container">
        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3957.653456383633!2d112.7374823153396!3d-7.279808994745582!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2dd7f9502931448b%3A0x633a694a1d48c8!2sGrand%20Mercure%20Surabaya%20Mirama!5e0!3m2!1sid!2sid!4v1700000000000!5m2!1sid!2sid" width="100%" height="400" style="border:0;" allowfullscreen="" loading="lazy"></iframe>
    </section>

    <!-- Gallery -->
    <section class="container section-padding text-center">
        <h2 class="section-title">Gallery</h2>
        <div class="row mt-5">
            <div class="col-md-4"><img src="https://images.unsplash.com/photo-1511285560929-80b456fea0bc?auto=format&fit=crop&w=800&q=80" class="gallery-img" alt="Gallery 1"></div>
            <div class="col-md-4"><img src="https://images.unsplash.com/photo-1519225421980-715cb0215aed?auto=format&fit=crop&w=800&q=80" class="gallery-img" alt="Gallery 2"></div>
            <div class="col-md-4">
                <div class="ratio ratio-9x16 gallery-img">
                    <!-- Ganti ID_VIDEO_DRIVE dengan ID video Anda -->
                    <iframe src="https://www.youtube.com/embed/dQw4w9WgXcQ" title="Video" allowfullscreen></iframe>
                </div>
            </div>
        </div>
    </section>

    <!-- RSVP & Wishes -->
    <section class="container section-padding">
        <div class="row g-5">
            <!-- RSVP Form -->
            <div class="col-md-6 tex
